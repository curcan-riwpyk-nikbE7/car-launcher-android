<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/rail_bg" />
            <stroke
                android:width="2.5dp"
                android:color="@color/accent_cyan" />
        </shape>
    </item>
    <item android:top="9dp" android:bottom="9dp" android:left="9dp" android:right="9dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/accent_cyan"
                android:endColor="@color/accent_purple" />
        </shape>
    </item>
</layer-list>
